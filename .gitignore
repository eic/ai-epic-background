# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C/C++ build artifacts
build/
*.o
*.so
*.a

# Python packaging
*.egg-info/
.Python
dist/
.eggs/

# Virtual envs
.venv
venv/
env/

# UV / poetry locks (keep project-level uv.lock if you want pinned deps)
uv.lock

# Editor / IDE
.idea/
.vscode/
*.swp

# OS
.DS_Store
Thumbs.db

# VitePress / Node
docs/node_modules/
docs/.vitepress/cache/
docs/.vitepress/dist/

# Output data (do not commit campaign products)
data/
plots/
*.root
*.csv
*.csv.zip

# Logs
*.log
logs/

# Claude / agent worktrees — but keep shared skills tracked
.claude/*
!.claude/skills/
